  "$id": "https://velocitron.dev/spec/petrinet-contribution-ir.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A portable, progressive, target-neutral intermediate representation for .petrinet source documents.",
  "properties": {
    "contributions": {
      "$comment": "Items MUST have unique source-derived id values and ordinal values 0..length-1 without gaps, ordered by ordinal.",
      "items": {
        "$ref": "#/$defs/contribution"
      },
      "type": "array"
    },
    "document": {
      "$ref": "#/$defs/documentIdentity"
    },
    "documentKind": {
      "description": "The source document's explicit kind.",
      "enum": [
        "net",
        "composition"
      ]
    },
    "format": {
      "const": "velocitron.petrinet/contribution-ir",
      "description": "The only supported IR format identifier."
    },
    "version": {
      "const": 1,
      "description": "The only supported IR format version."
    }
  },
  "required": [
    "format",
    "version",
    "documentKind",
    "document",
    "contributions"
  ],
  "title": "Velocitron Petri Net Contribution IR v1",
  "type": "object"
}

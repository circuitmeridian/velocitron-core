      "$comment": "Resolver accepts this kind only for net documents and validates position as the v1 {x:number,y:number} value.",
      "properties": {
        "kind": {
          "const": "view.position"
        },
        "target": {
          "$ref": "#/$defs/viewTarget"
        },
        "value": {
          "additionalProperties": false,
          "properties": {

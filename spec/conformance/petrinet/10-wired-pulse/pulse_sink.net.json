    {
      "accepts": [
        "pulse"
      ],
      "name": "pulse_in",
      "port": {
        "direction": "input",
        "type": "pulse"
      }
    },
    {
      "accepts": [
        "receipt"
      ],
      "name": "received"
    }
  ],
  "transitions": [
    {
      "handler": "receive@sink",
      "name": "receive"
    }
  ]

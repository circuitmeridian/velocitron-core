{
  "arcs": [
    {
      "consume": {
        "type": "pulse"
      },
      "from": {
        "place": "pulse_in"
      },
      "to": {
        "transition": "receive"
      }
    },
    {
      "from": {
        "transition": "receive"
      },
      "produce": {
        "destination": "received",
        "type": "receipt"
      },
      "to": {
        "place": "received"
      }
    }
  ],
  "description": "Pulse sink",
  "initialMarking": {},
  "name": "pulse_sink",

{
  "arcs": [
    {
      "consume": {
        "type": "tick_latch"
      },
      "from": {
        "place": "tick_latch"
      },
      "to": {
        "transition": "on_tick"
      }
    },
    {
      "from": {
        "transition": "on_tick"
      },
      "produce": {
        "destination": "tick_latch",
        "type": "tick_latch"
      },
      "to": {
        "place": "tick_latch"
      }
    },
    {
      "consume": {
        "mode": "read",
        "type": "clock"
      },
      "from": {
        "place": "clock"
      },
      "to": {
        "transition": "on_tick"
      }
    },
    {
      "from": {
        "transition": "on_tick"
      },
      "produce": {
        "destination": "refresh_due_out",
        "type": "refresh_due"
      },
      "to": {
        "place": "refresh_due_out"
      }
    }
  ],
  "description": "Cadence graduation fragment",
  "initialMarking": {
    "clock": [
      {
        "data": {
          "now": 0
        },
        "type": "clock"
      }
    ],
    "tick_latch": [
      {
        "data": {
          "cadence_s": 300,
          "fired_at": 0
        },
        "type": "tick_latch"
      }
    ]
  },
  "name": "graduation_cadence",
  "places": [
    {
      "accepts": [
        "tick_latch"
      ],
      "name": "tick_latch"
    },
    {
      "accepts": [
        "clock"
      ],
      "name": "clock"
    },
    {
      "accepts": [
        "refresh_due"
      ],
      "name": "refresh_due_out",
      "port": {
        "direction": "output",
        "type": "refresh_due"
      }
    }
  ],
  "transitions": [
    {
      "handler": "on_tick@cadence",
      "name": "on_tick",
      "timer": {
        "bind": {
          "latch": "tick_latch"
        },
        "cel": "clock.now >= latch.fired_at + latch.cadence_s",
        "clock": "clock"
      }
    }
  ]
}
